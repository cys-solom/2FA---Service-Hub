# Mailcow IMAP Configuration — Domain 1
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_USER=inbox@yourdomain.com
IMAP_PASS=your_password
MAIL_DOMAIN=yourdomain.com

# Domain 2 (optional)
IMAP_HOST_2=mail.yourdomain2.com
IMAP_PORT_2=993
IMAP_USER_2=inbox@yourdomain2.com
IMAP_PASS_2=your_password
MAIL_DOMAIN_2=yourdomain2.com

# Comma-separated list of all allowed domains
MAIL_DOMAINS=yourdomain.com,yourdomain2.com
